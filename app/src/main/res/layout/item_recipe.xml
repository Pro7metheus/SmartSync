<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">

        <TextView android:id="@+id/tv_recipe_name" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textAppearance="?attr/textAppearanceTitleMedium" android:textColor="?attr/colorOnSurface" android:textStyle="bold" android:maxLines="2" android:ellipsize="end" />

        <com.google.android.material.chip.Chip android:id="@+id/chip_match" style="@style/Widget.Material3.Chip.Assist" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorOnPrimary" android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">

        <TextView android:id="@+id/tv_category" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceLabelMedium" android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  •  " android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView android:id="@+id/tv_calories" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceLabelMedium" android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  •  " android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView android:id="@+id/tv_ingredients_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textAppearance="?attr/textAppearanceLabelMedium" android:textColor="?attr/colorOnSurfaceVariant" />
    </LinearLayout>
</LinearLayout>
