<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearance.SmartPantry.Rounded" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">16dp</item>
    </style>
